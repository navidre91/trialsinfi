  "clinical_axes": {
    "castration_status": {
      "description": "Current gonadal testosterone level relative to castrate threshold (<50 ng/dL)",
      "values": ["castration_sensitive", "castration_resistant", "unknown"],
      "detection_rules": {
        "castration_resistant": ["castration.resistant","CRPC","\\bCRPC\\b","hormone.refractory","androgen.independent","castrate.resistant"],
        "castration_sensitive": ["castration.sensitive","hormone.sensitive","castration.naive","hormone.naive","CSPC","HSPC","mHSPC","mCSPC"]
      },
      "_ui_note": "If castration_status=unknown and trial targets a specific castration state: surface trial with flag 'Confirm castration status — is the patient hormone-sensitive (CSPC) or castration-resistant (CRPC)? This determines which trials he qualifies for.'"
    },
    "metastatic_status": {
      "description": "Presence of distant metastases (M0 vs M1)",
      "values": ["localized", "regional_n1", "nonmetastatic_crpc", "metastatic", "unknown"],
      "detection_rules": {
        "localized": ["\\bcT[12]\\b","\\bcT1\\b","clinically.localized","localized.*prostate"],
        "regional_n1": ["\\bN1\\b.*prostate","node.positive.*prostate","pelvic.lymph.node.*positive"],
        "nonmetastatic_crpc": ["\\bnmCRPC\\b","M0.*CRPC","M0.*castration.resistant"],
        "metastatic": ["\\bM1\\b","metastatic.*prostate","\\bmCSPC\\b","\\bmCRPC\\b","bone.metastas","lymph.node.metastas.*distant"]
      },
      "_ui_note": "If metastatic_status=unknown: surface trials across localized and metastatic settings with flag 'Confirm staging — is there evidence of distant metastases on imaging? This is the single most important factor for narrowing the trial list.'"
    },
    "disease_volume": {
      "description": "Metastatic burden (CHAARTED criteria or similar)",
      "values": ["low_volume", "high_volume", "oligometastatic", "unknown"],
