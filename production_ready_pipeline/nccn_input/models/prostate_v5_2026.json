  "changelog": [
    {
      "date": "2026-04-02",
      "version": "1.1",
      "changes": [
        "Split localized_unfavorable_ir_high_risk into two separate categories: localized_unfavorable_ir and localized_high_very_high_risk. Validated by GUIDANCE trial — unfavorable IR and high risk have distinct SOC backbones and separate Phase III trial populations.",
        "Added genomic_classifier clinical axis (Decipher, Oncotype GPS, Prolaris) — validated by GUIDANCE trial design.",
        "Strengthened bcr_post_rp include_patterns for PET-guided salvage RT trials (INDICATE pattern). Added PSMA-PET + BCR post-RP signal patterns.",
        "Added INDICATE and GUIDANCE to known_trial_anchors as real-world validation cases."
      ]
    }
  ],
